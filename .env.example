# Multi-Agent Research System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === Required ===
GROQ_API_KEY=
TAVILY_API_KEY=

# === Optional — Memory (Mem0 Platform) ===
# Get your API key at https://app.mem0.ai/
# Without this key, memory features are silently disabled.
MEM0_API_KEY=

# === Groq LLM Settings ===
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TIMEOUT=30
# GROQ_MAX_RETRIES=3

# === Tavily Search Settings ===
# TAVILY_MAX_RESULTS=5

# === Context Management ===
# MAX_CONTEXT_CHARS=16000

# === Logging ===
# LOG_LEVEL=INFO
